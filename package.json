{
  "name": "tablogger",
  "version": "0.1.0",
  "description": "Universal logging function — tablog() works on frontend, backend, any language",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "tablogger": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "logging",
    "debug",
    "unified",
    "fullstack",
    "devtools",
    "tablog"
  ],
  "license": "MIT",
  "dependencies": {
    "picocolors": "^1.1.1",
    "tablogger": "^0.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
