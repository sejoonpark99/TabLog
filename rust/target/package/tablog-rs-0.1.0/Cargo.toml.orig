[package]
name = "tablog-rs"
version = "0.1.0"
edition = "2021"
description = "Rust SDK for tablogger — universal log viewer"
license = "MIT"
repository = "https://github.com/your-org/alt-tab"
keywords = ["logging", "debugging", "tablogger", "devtools"]
categories = ["development-tools::debugging"]

[lib]
name = "tablog"

[dependencies]
tungstenite = { version = "0.24", default-features = false, features = ["handshake"] }
serde_json = "1"
